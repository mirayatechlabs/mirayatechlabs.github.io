    <footer>
      <div class="max-w-7xl">
        <a href="#">
          Miraya<span style="color: #00A5B5">.</span>
        </a>
        <p>{t.footer.copyright}</p>
      </div>
    </footer>

    <div id="chatbot-container">
      <div id="chatbot-window" class="hidden">
        <div class="chatbot-header">
          <span>Miraya Assistant</span>
          <button id="chatbot-close">✕</button>
        </div>
        <div class="chatbot-body" id="chatbot-body">
          <p class="bot-msg">Ciao! Vuoi scoprire come posso migliorare la tua presenza online?</p>
        </div>
        <div class="chatbot-input">
          <input type="text" id="chatbot-input-field" placeholder="Scrivi qui..." />
          <button id="chatbot-send">Invia</button>
        </div>
      </div>
      <button id="chatbot-toggle" aria-label="Apri chat">
        <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
      </button>
    </div>

    <script src="/script.js" is:inline></script>
    <script>
      // Invio form via Web3Forms (sito statico, nessun backend).
      const form = document.getElementById('contact-form') as HTMLFormElement | null;
      const result = form?.querySelector('.form-result') as HTMLElement | null;
      const button = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!result || !button) return;

        const defaultLabel = button.dataset.defaultLabel ?? button.textContent ?? '';
        result.textContent = '';
        result.classList.remove('is-success', 'is-error');
        button.disabled = true;
        button.textContent = '…';

        try {
          const payload = Object.fromEntries(new FormData(form).entries());
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await response.json();

          if (response.ok && data.success) {
            form.reset();
            result.textContent = result.dataset.success ?? 'OK';
            result.classList.add('is-success');
          } else {
            result.textContent = result.dataset.error ?? 'Error';
            result.classList.add('is-error');
          }
        } catch {
          result.textContent = result.dataset.error ?? 'Error';
          result.classList.add('is-error');
        } finally {
          button.disabled = false;
          button.textContent = defaultLabel;
        }
      });
    </script>
  </body>
</html>
