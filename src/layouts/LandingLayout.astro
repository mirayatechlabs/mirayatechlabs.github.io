    <script src="/script.js" is:inline></script>
    <script>
      // Mandala di geometria sacra nella hero: anelli concentrici, seme della
      // vita e solidi platonici annidati in wireframe. Se WebGL non è
      // disponibile resta visibile il fallback SVG statico.
      import * as THREE from 'three';

      const canvas = document.getElementById('mandala-canvas') as HTMLCanvasElement | null;
      const figure = canvas?.closest('.hero-figure') as HTMLElement | null;

      if (canvas && figure) {
        try {
          initMandala(canvas, figure);
        } catch {
          // WebGL assente o contesto non creabile: il fallback SVG resta visibile.
        }
      }

      function initMandala(canvas: HTMLCanvasElement, figure: HTMLElement) {
        const INK = 0x221a12;
        const TERRACOTTA = 0xc0532f;
        const OCHRE = 0xd9a441;

        const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(40, 1, 0.1, 50);
        camera.position.z = 9;

        const group = new THREE.Group();
        scene.add(group);

        const lineMat = (color: number, opacity: number) =>
          new THREE.LineBasicMaterial({ color, transparent: true, opacity });

        const circlePoints = (radius: number, segments = 96) => {
          const pts: THREE.Vector3[] = [];
          for (let s = 0; s < segments; s++) {
            const a = (s / segments) * Math.PI * 2;
            pts.push(new THREE.Vector3(Math.cos(a) * radius, Math.sin(a) * radius, 0));
          }
          return pts;
        };

        const addRing = (radius: number, opacity: number, color = INK) => {
          const geo = new THREE.BufferGeometry().setFromPoints(circlePoints(radius));
          group.add(new THREE.LineLoop(geo, lineMat(color, opacity)));
        };

        // Anelli concentrici
        addRing(1.4, 0.4);
        addRing(2.3, 0.3);
        addRing(3.1, 0.35, OCHRE);

        // Seme della vita: sei cerchi attorno al centro
        for (let k = 0; k < 6; k++) {
          const a = (k / 6) * Math.PI * 2;
          const geo = new THREE.BufferGeometry().setFromPoints(circlePoints(1.4));
          const ring = new THREE.LineLoop(geo, lineMat(INK, 0.16));
          ring.position.set(Math.cos(a) * 1.4, Math.sin(a) * 1.4, 0);
          group.add(ring);
        }

        // Solidi platonici annidati in wireframe
        const ico = new THREE.LineSegments(
          new THREE.EdgesGeometry(new THREE.IcosahedronGeometry(1.55)),
          lineMat(INK, 0.5)
        );
        const octa = new THREE.LineSegments(
          new THREE.EdgesGeometry(new THREE.OctahedronGeometry(0.95)),
          lineMat(TERRACOTTA, 0.75)
        );
        group.add(ico, octa);

        // Punti oro sui vertici dell'icosaedro
        const icoPts = new THREE.Points(
          new THREE.IcosahedronGeometry(1.55),
          new THREE.PointsMaterial({ color: OCHRE, size: 0.07, transparent: true, opacity: 0.9 })
        );
        group.add(icoPts);

        // Corona di punti sull'anello esterno
        const crown = new THREE.Points(
          new THREE.BufferGeometry().setFromPoints(circlePoints(3.1, 36)),
          new THREE.PointsMaterial({ color: TERRACOTTA, size: 0.05, transparent: true, opacity: 0.8 })
        );
        group.add(crown);

        const resize = () => {
          const w = figure.clientWidth;
          const h = figure.clientHeight;
          renderer.setSize(w, h, false);
          camera.aspect = w / h;
          camera.updateProjectionMatrix();
        };
        resize();
        window.addEventListener('resize', resize);

        figure.classList.add('mandala-live');

        // Reattività dinamica e parallasse verso il puntatore
        let targetX = 0;
        let targetY = 0;
        let mouseSpeed = 0;
        let lastX = window.innerWidth / 2;
        let lastY = window.innerHeight / 2;
        let lastEventTime = performance.now();

        window.addEventListener('pointermove', (e) => {
          const now = performance.now();
          const dt = Math.max(1, now - lastEventTime);
          const dx = e.clientX - lastX;
          const dy = e.clientY - lastY;
          
          // Calcola la velocità del mouse per aggiungere dinamismo (moltiplicatore aumentato)
          mouseSpeed = Math.min(2.0, mouseSpeed + (Math.sqrt(dx*dx + dy*dy) / dt) * 0.15);

          lastX = e.clientX;
          lastY = e.clientY;
          lastEventTime = now;

          // Ampio parallasse (fino a 180 gradi di rotazione)
          targetY = (e.clientX / window.innerWidth - 0.5) * 3.0;
          targetX = (e.clientY / window.innerHeight - 0.5) * 3.0;
        });

        const clock = new THREE.Clock();
        const animate = () => {
          const t = clock.getElapsedTime();
          mouseSpeed *= 0.98; // decadimento più lento

          // Velocità base molto più alta per non sembrare fermo
          group.rotation.z = t * (0.15 + mouseSpeed * 0.5);
          ico.rotation.x = t * (0.25 + mouseSpeed * 0.6);
          ico.rotation.y = t * (0.20 + mouseSpeed * 0.6);
          icoPts.rotation.copy(ico.rotation);
          octa.rotation.x = -t * (0.30 + mouseSpeed * 0.8);
          octa.rotation.y = -t * (0.25 + mouseSpeed * 0.8);

          // Respiro visibile del mandala + forte espansione reattiva al mouse
          const breath = 1 + Math.sin(t * 1.5) * 0.05 + mouseSpeed * 0.25;
          group.scale.setScalar(breath);

          // Parallasse inerziale reattivo
          group.rotation.x += (targetX - group.rotation.x) * 0.08;
          group.rotation.y += (targetY - group.rotation.y) * 0.08;

          renderer.render(scene, camera);
          requestAnimationFrame(animate);
        };
        animate();
      }
    </script>
    <script>
      // Invio form via Web3Forms (sito statico, nessun backend).
      const form = document.getElementById('contact-form') as HTMLFormElement | null;
      const result = form?.querySelector('.form-result') as HTMLElement | null;
      const button = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!result || !button) return;

        const defaultLabel = button.dataset.defaultLabel ?? button.textContent ?? '';
        result.textContent = '';
        result.classList.remove('is-success', 'is-error');
        button.disabled = true;
        button.textContent = '…';

        try {
          const payload = Object.fromEntries(new FormData(form).entries());
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await response.json();

          if (response.ok && data.success) {
            form.reset();
            result.textContent = result.dataset.success ?? 'OK';
            result.classList.add('is-success');
          } else {
            result.textContent = result.dataset.error ?? 'Error';
            result.classList.add('is-error');
          }
        } catch {
          result.textContent = result.dataset.error ?? 'Error';
          result.classList.add('is-error');
        } finally {
          button.disabled = false;
          button.textContent = defaultLabel;
        }
      });
    </script>
  </body>
