---
// BaseLayout — placeholder minimo per Phase 1
// Implementazione completa: Phase 2, piano 02-01
interface Props {
  title?: string;
  description?: string;
  lang?: string;
}
const { title = 'mirayatechlabs.', description = '', lang = 'it' } = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <slot />
  </body>
</html>
