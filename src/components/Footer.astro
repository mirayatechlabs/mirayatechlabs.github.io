---
interface Props {
  lang: string;
}

const { lang } = Astro.props;
const isIT = lang === 'it';
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">mirayatechlabs.</span>
      <p class="footer-tagline">
        {isIT
          ? 'Sartoria digitale e AI per liberare tempo umano.'
          : 'Digital craft and AI to free up human time.'}
      </p>
    </div>

    <div class="footer-meta">
      <a href="mailto:mirayatechlabs@gmail.com">mirayatechlabs@gmail.com</a>
      <span>{isIT ? 'Milano, IT' : 'Milan, IT'}</span>
    </div>
  </div>

  <div class="footer-copy">
    <div class="container">© 2026 mirayatechlabs.</div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    background-color: var(--color-bs-surface-0);
    color: var(--color-bs-foreground-light);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-top: 2.5rem;
    padding-bottom: 2rem;
    flex-wrap: wrap;
  }

  .footer-brand {
    display: grid;
    gap: 0.25rem;
  }

  .footer-logo {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.1rem;
  }

  .footer-tagline {
    margin: 0;
    max-width: 34ch;
    font-size: 0.9rem;
    color: var(--color-bs-foreground-dark);
  }

  .footer-meta {
    display: grid;
    justify-items: end;
    gap: 0.25rem;
    font-size: 0.9rem;
    color: var(--color-bs-foreground-dark);
  }

  .footer-meta a {
    font-family: var(--font-sans);
    font-weight: 700;
    color: var(--color-bs-foreground-light);
    text-decoration: none;
  }

  .footer-meta a:hover {
    color: var(--color-rame-light);
  }

  .footer-copy {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1rem 0;
    font-size: 0.8rem;
    color: var(--color-bs-foreground-dark);
  }

  @media (max-width: 640px) {
    .footer-meta {
      justify-items: start;
    }
  }
</style>
