---
// Fascione "showreel": striscia scura che scorre alternando parole-valore e
// riquadri dei lavori reali. Se un item ha `video`, mostra la clip; altrimenti
// un placeholder on-brand con didascalia (pronto per quando arrivano i video).
interface ReelItem {
  caption: string;
  video?: string;
}
interface Props {
  words: string[];
  reel: ReelItem[];
}
const { words, reel } = Astro.props;

// Interleave: parola, riquadro, parola, riquadro…
type Cell = { type: 'word'; value: string } | { type: 'tile'; item: ReelItem };
const cells: Cell[] = [];
const n = Math.max(words.length, reel.length);
for (let i = 0; i < n; i++) {
  if (words[i]) cells.push({ type: 'word', value: words[i] });
  if (reel[i]) cells.push({ type: 'tile', item: reel[i] });
}
// Duplicato per lo scroll infinito (la GSAP anima xPercent -50)
const strip = [...cells, ...cells];
---

<div class="marquee-wrapper" aria-hidden="true">
  <div class="marquee-content reel-strip">
    {strip.map((cell) =>
      cell.type === 'word' ? (
        <div class="reel-word">
          {cell.value}
          <span aria-hidden="true">◆</span>
        </div>
      ) : (
        <div class="reel-tile">
          {cell.item.video ? (
            <video
              src={cell.item.video}
              muted
              loop
              autoplay
              playsinline
              preload="metadata"
            />
          ) : (
            <div class="reel-ph">
              <span class="reel-rec" aria-hidden="true"></span>
              <p>{cell.item.caption}</p>
            </div>
          )}
        </div>
      )
    )}
  </div>
</div>

<style>
  .marquee-wrapper {
    width: 100%;
    overflow: hidden;
    padding: 2.5rem 0;
    background: var(--ink);
    color: var(--paper);
    position: relative;
    z-index: 10;
    border-top: 1px solid rgba(217, 159, 62, 0.25);
    border-bottom: 1px solid rgba(217, 159, 62, 0.25);
  }

  .marquee-content {
    display: flex;
    align-items: center;
    white-space: nowrap;
    width: max-content;
    will-change: transform;
  }

  .reel-word {
    padding: 0 2.25rem;
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    font-family: var(--serif);
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    font-weight: 500;
    letter-spacing: 0.01em;
    flex: none;
  }

  .reel-word span {
    color: var(--violet-bright);
    font-size: 0.55em;
  }

  .reel-word:nth-of-type(4n) span {
    color: var(--ochre);
  }

  .reel-tile {
    flex: none;
    width: clamp(220px, 26vw, 340px);
    aspect-ratio: 16 / 10;
    margin: 0 1.25rem;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(217, 159, 62, 0.35);
    background: #171009;
    position: relative;
  }

  .reel-tile video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .reel-ph {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 1rem 1.1rem;
    background:
      radial-gradient(120% 90% at 80% 0%, rgba(192, 83, 47, 0.22), transparent 60%),
      radial-gradient(120% 90% at 0% 100%, rgba(217, 159, 62, 0.16), transparent 55%);
  }

  .reel-ph p {
    margin: 0;
    font-family: var(--serif);
    font-size: 1rem;
    line-height: 1.3;
    color: var(--paper);
    max-width: 90%;
    white-space: normal;
  }

  .reel-rec {
    position: absolute;
    top: 0.85rem;
    left: 0.9rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--terracotta);
    box-shadow: 0 0 0 0 rgba(217, 94, 64, 0.6);
    animation: reel-pulse 1.8s ease-out infinite;
  }

  @keyframes reel-pulse {
    0% { box-shadow: 0 0 0 0 rgba(217, 94, 64, 0.6); }
    70% { box-shadow: 0 0 0 8px rgba(217, 94, 64, 0); }
    100% { box-shadow: 0 0 0 0 rgba(217, 94, 64, 0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .reel-rec { animation: none; }
  }
</style>
