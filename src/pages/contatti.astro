---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contatti — Miraya Tech Labs"
  description="Scrivi a mirayatechlabs@gmail.com o prenota un confronto: rispondiamo entro 24 ore."
  lang="it"
>
  <section class="page-hero section">
    <div class="container">
      <p class="eyebrow">Contatti</p>
      <h1>Progettiamo il tuo futuro digitale.</h1>
      <p class="hero-sub">
        Hai una domanda, un progetto o vuoi capire se possiamo aiutarti a migliorare un processo.
        Scrivici: rispondiamo entro 24 ore nei giorni lavorativi.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="contact-panel card-surface">
        <span class="contact-label">Email</span>
        <a href="mailto:mirayatechlabs@gmail.com">mirayatechlabs@gmail.com</a>
        <p>È il canale che controlliamo con più attenzione.</p>
      </div>

      <div class="contact-panel card-surface">
        <span class="contact-label">Sede</span>
        <p>Milano, IT</p>
        <p>Operiamo in remoto e su appuntamento, con presenza dove serve.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-top: 4.5rem;
  }

  .hero-sub {
    max-width: 58ch;
    color: var(--color-bs-foreground-dark);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .contact-panel {
    display: grid;
    gap: 0.6rem;
  }

  .contact-label {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-rame-light);
  }

  .contact-panel a {
    font-family: var(--font-sans);
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    font-weight: 700;
    word-break: break-word;
  }

  .contact-panel p {
    margin: 0;
    color: var(--color-bs-foreground-dark);
  }

  @media (max-width: 720px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
