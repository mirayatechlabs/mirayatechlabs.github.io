---
// EN homepage — /en/
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="mirayatechlabs. — AI automation for Italian SMEs"
  description="Website, chatbot and automations for SMEs that don't want to waste time. Tatiana Camillucci, AI consultant in Le Marche, Italy."
  lang="en"
>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1>AI automation for SMEs that don't want to waste time.</h1>
      <p class="hero-sub">
        Website, chatbot, automations. We include a responsive chatbot on your site. We build what you actually need — no smoke, no incomprehensible contracts.
      </p>
      <div class="hero-cta">
        <a href="/en/configurator/" class="btn-primary">Choose your package</a>
        <a href="/en/services/" class="btn-secondary">How it works</a>
      </div>
    </div>
  </section>

  <!-- Who's behind it -->
  <section class="chi-section">
    <div class="container chi-inner">
      <div class="chi-foto" aria-hidden="true">photo</div>
      <div class="chi-testo">
        <h2>Who's behind this</h2>
        <p>
          My name is Tatiana. I worked as a midwife for ten years, then started studying cultural anthropology, then learned to code.
          Today I help businesses use AI without losing their minds — or losing sight of people.
        </p>
        <a href="/en/contact/" class="link-rame">Get in touch →</a>
      </div>
    </div>
  </section>

  <!-- What you can get -->
  <section class="cosa-section">
    <div class="container">
      <h2 class="section-title">What you can get</h2>
      <div class="card-grid">
        <div class="service-card">
          <div class="card-icon" aria-hidden="true">💬</div>
          <h3>Your site answers customers even at night</h3>
          <p>An AI chatbot trained on your business answers FAQs, collects leads, and never misses an opportunity.</p>
        </div>
        <div class="service-card">
          <div class="card-icon" aria-hidden="true">⚙️</div>
          <h3>Stop doing the same things by hand every week</h3>
          <p>Emails, reminders, syncing with your management software. The system handles repetitive tasks — you do other things.</p>
        </div>
        <div class="service-card">
          <div class="card-icon" aria-hidden="true">📊</div>
          <h3>Your data tells you something useful</h3>
          <p>Stop collecting data without understanding it. We build you a tool that answers concrete questions about your business.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="cta-finale">
    <div class="container">
      <h2>Have a project in mind? Let's talk.</h2>
      <p>No commitment, no aggressive sales pitch. Just a conversation about what you actually need.</p>
      <a href="/en/contact/" class="btn-primary">Get in touch</a>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    background:
      radial-gradient(circle at 20% 20%, rgba(193, 106, 42, 0.25), transparent 55%),
      radial-gradient(circle at 80% 0%, rgba(107, 143, 113, 0.2), transparent 45%),
      var(--color-bs-surface-1);
    color: var(--color-bs-foreground-light);
    padding: 5rem 0 4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .hero h1 { color: var(--color-bs-foreground-light); max-width: 18ch; margin-bottom: 1.25rem; }
  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--color-bs-foreground-dark);
    max-width: 52ch;
    margin-bottom: 2rem;
  }

  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }

  .full-width { width: 100%; text-align: center; }

  .chi-section { padding: 4.5rem 0; background-color: var(--color-bs-surface-2); }
  .chi-inner { display: flex; align-items: center; gap: 3rem; flex-wrap: wrap; }
  .chi-foto {
    flex-shrink: 0; width: 200px; height: 200px;
    background: linear-gradient(135deg, rgba(193, 106, 42, 0.75), rgba(107, 143, 113, 0.6));
    color: var(--color-bs-foreground-light);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-sans); font-size: 0.875rem; border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }
  .chi-testo { max-width: 48ch; }
  .chi-testo h2 { margin-bottom: 0.75rem; }
  .chi-testo p { color: var(--color-bs-foreground-dark); margin-bottom: 1rem; }
  .link-rame { font-family: var(--font-sans); font-weight: 700; color: var(--color-rame-light); text-decoration: none; }
  .link-rame:hover { color: var(--color-rame); }

  .cosa-section { padding: 4.5rem 0; }
  .section-title { margin-bottom: 0.5rem; }
  .section-intro { color: var(--color-bs-foreground-dark); margin-bottom: 2.5rem; }

  .card-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem; }
  .service-card {
    padding: 1.75rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    background-color: rgba(255, 255, 255, 0.02);
    transition: border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  .service-card:hover { border-color: rgba(193, 106, 42, 0.7); transform: translateY(-2px); box-shadow: 0 16px 30px rgba(0, 0, 0, 0.3); }
  .card-icon { font-size: 1.75rem; margin-bottom: 0.75rem; }
  .service-card h3 { font-size: 1.05rem; margin-bottom: 0.5rem; }
  .service-card p { font-size: 0.9rem; color: var(--color-bs-foreground-dark); margin-bottom: 0; max-width: none; }

  .prezzi-section { padding: 4.5rem 0; background-color: var(--color-bs-surface-2); }
  .prezzi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; max-width: 700px; }
  .prezzi-card {
    padding: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    background-color: var(--color-bs-surface-3);
  }
  .prezzi-card--featured {
    border-color: rgba(193, 106, 42, 0.8);
    background: linear-gradient(160deg, rgba(193, 106, 42, 0.25), rgba(17, 18, 24, 0.9));
    color: var(--color-bs-foreground-light);
  }
  .prezzi-card--featured h3 { color: var(--color-bs-foreground-light); }
  .prezzi-header { margin-bottom: 1.25rem; }
  .prezzi-header h3 { margin-bottom: 0.25rem; font-size: 1.2rem; }
  .prezzo { font-family: var(--font-sans); font-size: 1.75rem; font-weight: 700; color: var(--color-rame-light); }
  .prezzo span { font-size: 0.9rem; color: var(--color-bs-foreground-dark); font-weight: 400; }
  .prezzi-card--featured .prezzo span { color: color-mix(in srgb, var(--color-bs-foreground-light) 60%, transparent); }
  .prezzi-features { list-style: none; padding: 0; margin: 0 0 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .prezzi-features li { font-size: 0.9rem; color: var(--color-bs-foreground-dark); padding-left: 1.1rem; position: relative; }
  .prezzi-features li::before { content: '—'; position: absolute; left: 0; color: var(--color-rame-light); }
  .prezzi-card--featured .prezzi-features li { color: color-mix(in srgb, var(--color-bs-foreground-light) 70%, transparent); }

  .cta-finale { padding: 5rem 0; background-color: var(--color-bs-surface-0); color: var(--color-bs-foreground-light); text-align: center; }
  .cta-finale h2 { color: var(--color-bs-foreground-light); margin-bottom: 0.75rem; }
  .cta-finale p { color: color-mix(in srgb, var(--color-bs-foreground-light) 70%, transparent); max-width: 48ch; margin: 0 auto 2rem; }

  @media (max-width: 640px) {
    .hero { padding: 3.5rem 0 3rem; }
    .chi-foto { width: 120px; height: 120px; }
  }
</style>
