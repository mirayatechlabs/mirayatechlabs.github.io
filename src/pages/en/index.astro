---
import BaseLayout from '../../layouts/BaseLayout.astro';

const competencies = [
  {
    title: 'Web Design',
    subtitle: 'Intuitive Interfaces',
    text: 'Websites that are not just showcases, but conversion tools designed to guide people with naturalness and precision.',
  },
  {
    title: 'AI Software',
    subtitle: 'Smart Automation',
    text: 'We build custom software that integrates AI to remove repetitive tasks and optimize company workflows.',
  },
  {
    title: 'Process Optimization',
    subtitle: 'Process Engineering',
    text: 'We map bottlenecks in your business and solve them with tailored technology.',
  },
];

const benefits = [
  'Up to 60% less time spent on operational management.',
  'Interfaces designed to reduce cognitive load.',
  'Scalable software that grows with your company.',
];
---

<BaseLayout
  title="Miraya Tech Labs — Digital Craft & Artificial Intelligence"
  description="Web design, AI software and process optimization to free up human time and make your business more efficient."
  lang="en"
>
  <section class="hero section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Digital Craft &amp; Artificial Intelligence</p>
        <h1>Efficiency is a precise art.</h1>
        <p class="hero-text">
          We don't just build software, we shape processes. We combine cutting-edge web design with artificial
          intelligence to free up human time and optimize the heart of your business.
        </p>
        <div class="hero-actions">
          <a href="#contact" class="btn-primary">Optimize your business</a>
          <a href="#competencies" class="btn-secondary">Our competencies</a>
        </div>
      </div>

      <div class="hero-visual card-surface">
        <img src="/hero1.png" alt="Work table with sketches and technology" loading="eager" />
      </div>
    </div>
  </section>

  <section id="competencies" class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Our Competencies</p>
        <h2>Simplifying Complexity</h2>
      </div>

      <div class="competence-grid">
        {competencies.map((item) => (
          <article class="competence-card card-surface">
            <span class="competence-tag">{item.title}</span>
            <h3>{item.subtitle}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="philosophy" class="section section--alt">
    <div class="container philosophy-grid">
      <div>
        <p class="eyebrow">Technology that adapts to people</p>
        <h2>Human-centered, not invasive.</h2>
        <p class="philosophy-copy">
          We believe AI should not replace human intelligence, but amplify it. Our approach is anthropocentric:
          we create tools that simplify digital bureaucracy and give people back what really matters:
          creativity and strategy.
        </p>
      </div>

      <div class="philosophy-panel card-surface">
        <ul class="benefit-list">
          {benefits.map((benefit) => <li>{benefit}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section id="contact" class="section">
    <div class="container contact-grid">
      <div>
        <p class="eyebrow">Let's design your digital future.</p>
        <h2>Ready to turn your business processes into a competitive advantage?</h2>
        <p class="contact-copy">
          If you want to start with a concrete project, write to us and we'll reply with a clear proposal.
        </p>
      </div>

      <div class="contact-panel card-surface">
        <div>
          <span class="contact-label">Email</span>
          <a href="mailto:mirayatechlabs@gmail.com">mirayatechlabs@gmail.com</a>
        </div>
        <div>
          <span class="contact-label">Location</span>
          <p>Milan, IT</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 4.5rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
    gap: 2rem;
    align-items: center;
  }

  .hero-copy {
    max-width: 64ch;
  }

  .hero-text,
  .philosophy-copy,
  .contact-copy,
  .competence-card p,
  .contact-panel p {
    color: var(--color-bs-foreground-dark);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.75rem;
  }

  .hero-visual {
    overflow: hidden;
    padding: 0;
  }

  .hero-visual img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 420px;
    object-fit: cover;
  }

  .section-head {
    display: grid;
    gap: 0.35rem;
    margin-bottom: 1.5rem;
  }

  .competence-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .competence-card {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .competence-tag {
    display: inline-flex;
    width: fit-content;
    padding: 0.28rem 0.6rem;
    border-radius: 999px;
    border: 1px solid rgba(193, 106, 42, 0.18);
    background: rgba(193, 106, 42, 0.08);
    color: var(--color-rame-light);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .philosophy-grid,
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
    gap: 1.25rem;
    align-items: center;
  }

  .philosophy-panel {
    padding: 1.5rem;
  }

  .benefit-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
  }

  .benefit-list li {
    padding-left: 1.15rem;
    position: relative;
    color: var(--color-bs-foreground-dark);
  }

  .benefit-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-rame-light);
  }

  .contact-panel {
    display: grid;
    gap: 1.25rem;
  }

  .contact-label {
    display: block;
    margin-bottom: 0.2rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-rame-light);
  }

  .contact-panel a {
    font-family: var(--font-sans);
    font-weight: 700;
    word-break: break-word;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .philosophy-grid,
    .contact-grid,
    .competence-grid {
      grid-template-columns: 1fr;
    }

    .hero-visual img {
      min-height: 280px;
    }
  }
</style>
