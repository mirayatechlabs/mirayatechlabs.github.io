---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Miraya Tech Labs"
  description="Write to mirayatechlabs@gmail.com or book a conversation: we reply within 24 hours."
  lang="en"
>
  <section class="page-hero section">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Let's design your digital future.</h1>
      <p class="hero-sub">
        You have a question, a project, or you want to see whether we can help improve a process.
        Write to us and we'll reply within 24 hours on working days.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="contact-panel card-surface">
        <span class="contact-label">Email</span>
        <a href="mailto:mirayatechlabs@gmail.com">mirayatechlabs@gmail.com</a>
        <p>This is the channel we monitor most carefully.</p>
      </div>

      <div class="contact-panel card-surface">
        <span class="contact-label">Location</span>
        <p>Milan, IT</p>
        <p>We work remotely and in person when needed.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-top: 4.5rem;
  }

  .hero-sub {
    max-width: 58ch;
    color: var(--color-bs-foreground-dark);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .contact-panel {
    display: grid;
    gap: 0.6rem;
  }

  .contact-label {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-rame-light);
  }

  .contact-panel a {
    font-family: var(--font-sans);
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    font-weight: 700;
    word-break: break-word;
  }

  .contact-panel p {
    margin: 0;
    color: var(--color-bs-foreground-dark);
  }

  @media (max-width: 720px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
