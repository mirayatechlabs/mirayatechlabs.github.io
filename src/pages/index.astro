---
import BaseLayout from '../layouts/BaseLayout.astro';

const competenze = [
  {
    title: 'Web Design',
    subtitle: 'Interfacce Intuitive',
    text: 'Siti web che non sono solo vetrine, ma strumenti di conversione progettati per guidare l’utente con naturalezza e precisione.',
  },
  {
    title: 'AI Software',
    subtitle: 'Automazione Intelligente',
    text: 'Sviluppiamo software custom che integrano l’AI per eliminare i task ripetitivi e ottimizzare i flussi di lavoro aziendali.',
  },
  {
    title: 'Process Optimization',
    subtitle: 'Ingegneria dei Processi',
    text: 'Analizziamo il tuo business per mappare i colli di bottiglia e risolverli con soluzioni tecnologiche su misura.',
  },
];

const benefici = [
  'Riduzione dei tempi di gestione operativa fino al 60%.',
  'Interfacce studiate per minimizzare il carico cognitivo.',
  'Software scalabili che crescono con la tua impresa.',
];
---

<BaseLayout
  title="Miraya Tech Labs — Sartoria Digitale & Intelligenza Artificiale"
  description="Web design, AI software e ottimizzazione dei processi per liberare tempo umano e rendere più efficiente la tua azienda."
  lang="it"
>
  <section class="hero section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Sartoria Digitale &amp; Intelligenza Artificiale</p>
        <h1>L'efficienza è un'arte precisa.</h1>
        <p class="hero-text">
          Non implementiamo solo software, modelliamo processi. Fondiamo il Web Design d'avanguardia con
          l'Intelligenza Artificiale per liberare il tempo umano e ottimizzare il cuore della tua azienda.
        </p>
        <div class="hero-actions">
          <a href="#contact" class="btn-primary">Ottimizza il tuo business</a>
          <a href="#competenze" class="btn-secondary">Le competenze</a>
        </div>
      </div>

      <div class="hero-visual card-surface">
        <img src="/hero1.png" alt="Tavolo da lavoro con schizzi e tecnologia" loading="eager" />
      </div>
    </div>
  </section>

  <section id="competenze" class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Le Nostre Competenze</p>
        <h2>Semplificare la Complessità</h2>
      </div>

      <div class="competence-grid">
        {competenze.map((item) => (
          <article class="competence-card card-surface">
            <span class="competence-tag">{item.title}</span>
            <h3>{item.subtitle}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="filosofia" class="section section--alt">
    <div class="container philosophy-grid">
      <div>
        <p class="eyebrow">Tecnologia che si adatta all'uomo</p>
        <h2>_antropocentrica_, non invasiva.</h2>
        <p class="philosophy-copy">
          Crediamo che l'AI non debba sostituire l'intelligenza umana, ma potenziarla. Il nostro approccio è
          antropocentrico: creiamo strumenti che semplificano la burocrazia digitale per restituire alle persone
          ciò che conta davvero: la creatività e la strategia.
        </p>
      </div>

      <div class="philosophy-panel card-surface">
        <ul class="benefit-list">
          {benefici.map((benefit) => <li>{benefit}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section id="contact" class="section">
    <div class="container contact-grid">
      <div>
        <p class="eyebrow">Progettiamo il tuo futuro digitale.</p>
        <h2>Sei pronto a trasformare i tuoi processi aziendali in un vantaggio competitivo?</h2>
        <p class="contact-copy">
          Se vuoi partire con un progetto concreto, scrivici e ti rispondiamo con una proposta chiara.
        </p>
      </div>

      <div class="contact-panel card-surface">
        <div>
          <span class="contact-label">Email</span>
          <a href="mailto:mirayatechlabs@gmail.com">mirayatechlabs@gmail.com</a>
        </div>
        <div>
          <span class="contact-label">Sede</span>
          <p>Milano, IT</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 4.5rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
    gap: 2rem;
    align-items: center;
  }

  .hero-copy {
    max-width: 64ch;
  }

  .hero-text,
  .philosophy-copy,
  .contact-copy,
  .competence-card p,
  .contact-panel p {
    color: var(--color-bs-foreground-dark);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.75rem;
  }

  .hero-visual {
    overflow: hidden;
    padding: 0;
  }

  .hero-visual img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 420px;
    object-fit: cover;
  }

  .section-head {
    display: grid;
    gap: 0.35rem;
    margin-bottom: 1.5rem;
  }

  .competence-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .competence-card {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .competence-tag {
    display: inline-flex;
    width: fit-content;
    padding: 0.28rem 0.6rem;
    border-radius: 999px;
    border: 1px solid rgba(193, 106, 42, 0.18);
    background: rgba(193, 106, 42, 0.08);
    color: var(--color-rame-light);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .philosophy-grid,
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
    gap: 1.25rem;
    align-items: center;
  }

  .philosophy-panel {
    padding: 1.5rem;
  }

  .benefit-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
  }

  .benefit-list li {
    padding-left: 1.15rem;
    position: relative;
    color: var(--color-bs-foreground-dark);
  }

  .benefit-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-rame-light);
  }

  .contact-panel {
    display: grid;
    gap: 1.25rem;
  }

  .contact-label {
    display: block;
    margin-bottom: 0.2rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-rame-light);
  }

  .contact-panel a {
    font-family: var(--font-sans);
    font-weight: 700;
    word-break: break-word;
  }

  @media (max-width: 900px) {
    .hero-grid,
    .philosophy-grid,
    .contact-grid,
    .competence-grid {
      grid-template-columns: 1fr;
    }

    .hero-visual img {
      min-height: 280px;
    }
  }
</style>
