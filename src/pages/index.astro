---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/reference-design.css';
---

<BaseLayout
  title="Miraya Tech Labs — Artigianato Digitale"
  description="Laboratorio di artigianato digitale dove il codice è materia viva e gli algoritmi sono capolavori."
  lang="it"
>
  <main>
    <section class="hero" id="hero">
      <div class="container">
        <div class="hero-wrapper">
          <div class="hero-image">
            <img src="/hero1.png" alt="Miraya Tech Labs" />
          </div>
          <div class="hero-content">
            <p class="hero-label">Laboratorio di Artigianato Digitale</p>
            <h1 class="hero-title">L'Intelligenza è un <em>Gesto Umano</em>.</h1>
            <p class="hero-text">Trattiamo il codice come materia viva. Siamo artigiani del dato e sarti dell'algoritmo.</p>
            <a href="#contact" class="hero-cta">
              Iniziamo una conversazione
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="services" id="services">
      <div class="container">
        <div class="section-header">
          <h2>Il Nostro Artigianato</h2>
          <p>Tre discipline, una filosofia</p>
        </div>
        <div class="services-grid">
          <div class="service-card">
            <h3>Consulenza AI</h3>
            <p>Strategie di intelligenza artificiale innovative.</p>
          </div>
          <div class="service-card">
            <h3>Progettazione Web</h3>
            <p>Esperienze digitali estetiche e funzionali.</p>
          </div>
          <div class="service-card">
            <h3>Sviluppo Software</h3>
            <p>Codice pulito e architetture solide.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="contact" id="contact">
      <div class="container">
        <h2>Contattaci</h2>
        <p>Pronto a iniziare il tuo prossimo progetto?</p>
        <a href="mailto:info@mirayatechlabs.it" class="cta-button">Scrivi una email</a>
      </div>
    </section>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/aos@2/dist/aos.js"></script>
  <script>
    AOS.init();
  </script>
</BaseLayout>
